# Supabase 프로젝트 URL/anon key. 브라우저에 노출돼도 되는 값(anon key는 RLS로 보호됨).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key는 이 프로젝트 코드 어디에서도 사용하지 않는다 (RLS만으로 데이터 격리를 강제하는 정책).
# 값을 적더라도 .gitignore된 .env.local에만 두고, 코드/문서/대화에 절대 노출하지 않는다.
SUPABASE_SERVICE_ROLE_KEY=

# Make.com Webhook 엔드포인트. 서버에서만 사용하며 프론트엔드에 절대 노출하지 않는다.
MAKE_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# true(기본값)면 실제 Webhook 호출 없이 payload만 응답한다 (안전 우선).
# 실제 연동을 확인할 때만 잠깐 false로 바꾸고, 확인 후 다시 true로 되돌린다.
SILVERLINK_DRY_RUN=true

# false(기본값)면 /api/create-task는 Supabase에만 저장한다.
# true로 켜면 Supabase 저장 후 기존 Make Webhook도 레거시 호환 목적으로 같이 호출한다.
LEGACY_MAKE_SYNC_ENABLED=false
