# Supabase 프로젝트 URL/anon key. 브라우저에 노출돼도 되는 값(anon key는 RLS로 보호됨).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key는 이 프로젝트 코드 어디에서도 사용하지 않는다 (RLS만으로 데이터 격리를 강제하는 정책).
# 값을 적더라도 .gitignore된 .env.local에만 두고, 코드/문서/대화에 절대 노출하지 않는다.
SUPABASE_SERVICE_ROLE_KEY=

# Make.com Webhook 엔드포인트. 서버에서만 사용하며 프론트엔드에 절대 노출하지 않는다.
MAKE_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# true(기본값)면 실제 Webhook 호출 없이 payload만 응답한다 (안전 우선).
# 실제 연동을 확인할 때만 잠깐 false로 바꾸고, 확인 후 다시 true로 되돌린다.
SILVERLINK_DRY_RUN=true

# false(기본값)면 /api/create-task는 Supabase에만 저장한다.
# true로 켜면 Supabase 저장 후 기존 Make Webhook도 레거시 호환 목적으로 같이 호출한다.
LEGACY_MAKE_SYNC_ENABLED=false

# Google Gemini API 키(Day13+ RAG 챗봇/임베딩에 사용). 비워두면 /api/rag/ask가 LLM 호출 없이
# 결정론적 fallback 답변(buildFallbackAnswer)만 돌려준다 — 로컬에서 RAG 기능 없이도 빌드/테스트 가능.
GEMINI_API_KEY=

# 선택. 비워두면 코드 기본값(gemini-2.5-flash / gemini-embedding-001)을 쓴다.
GEMINI_LLM_MODEL=
GEMINI_EMBEDDING_MODEL=

# ── Day17: 실제 SMS 발송 (Solapi) ──────────────────────────────────────────
# true로 켜면 channel="sms" 발송 시 Solapi API를 실제로 호출한다. 기본값 false(Mock 동작).
# 처음 실제 발송 테스트를 할 때만 true로 바꾸고, 명시적으로 확인한 후에 사용할 것.
ENABLE_REAL_SMS=false

# Solapi API 자격증명 (solapi.com → API Key 관리)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=   # 발신번호 (본인인증으로 등록한 번호, 예: 01012345678)

# ── Day17: 실제 음성 TTS 전화 (Solapi Voice) ───────────────────────────────
# true로 켜면 channel="voice_call" 발송 시 Solapi Voice API를 실제로 호출한다. 기본값 false.
ENABLE_REAL_CALLS=false

# Solapi 음성 상태보고 웹훅 시크릿 (Solapi 콘솔 설정 → 상태보고 URL에 ?secret= 파라미터로 포함).
# 비워두면 /api/voice/solapi-status 엔드포인트가 503을 반환해 웹훅을 차단한다.
# 설정 전 docs/voice-webhook-setup.sql을 Supabase SQL 에디터에서 먼저 실행해야 한다.
SOLAPI_WEBHOOK_SECRET=

# ── Day20: 카카오 알림톡 (Solapi) ─────────────────────────────────────────────
# true로 켜면 channel="kakao_alimtalk" 발송 시 Solapi 카카오 알림톡 API를 실제로 호출한다.
# 기본값 false. 카카오 비즈니스 채널 승인 + 템플릿 심사 완료 후에만 true로 변경할 것.
ENABLE_REAL_KAKAO=false

# 카카오 비즈니스 채널 pfId (카카오 for business → 채널 → 채널 ID → Solapi 콘솔 연동 후 확인)
# 채널 승인 전에는 비워두고, 승인 후 등록. docs/deployment-guide.md 참고.
SOLAPI_KAKAO_PF_ID=

# 카카오 알림톡 템플릿 ID (Solapi 콘솔 → 카카오 서비스 → 알림톡 템플릿 심사 완료 후 발급)
# 템플릿은 사전 승인 필수 (영업일 1~3일 소요). 비워두면 발송 시 KAKAO_TEMPLATE_ID_MISSING 반환.
SOLAPI_KAKAO_TEMPLATE_ID=

# ── Day19: Vercel Cron 인증 시크릿 ────────────────────────────────────────────
# /api/cron/check-due-tasks 엔드포인트를 외부에서 임의로 호출하지 못하게 막는 비밀 값.
# openssl rand -hex 32 로 생성하거나 임의의 긴 문자열을 사용한다.
# Vercel 환경변수와 로컬 .env.local 양쪽에 동일한 값을 등록한다.
CRON_SECRET=
